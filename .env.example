
# Added by skill
TELEGRAM_BOT_TOKEN=

# Model proxy — change these 3 lines to switch providers (DashScope, Kimi, etc.)
# When set, a local HTTP proxy rewrites requests from the container SDK to use
# MODEL_ID and API_KEY, then forwards to API_BASE_URL.
# If API_BASE_URL is absent, the proxy is not started and Claude credentials
# (ANTHROPIC_API_KEY / CLAUDE_CODE_OAUTH_TOKEN) are used directly.
# API_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic
# API_KEY=sk-...
# MODEL_ID=glm-5
